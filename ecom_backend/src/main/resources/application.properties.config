# ──────────────────────────────────────────────────────────────
# E-Commerce Backend — Configuration Template
# ──────────────────────────────────────────────────────────────
# All values support environment variable overrides via ${ENV_VAR:default}.
# Copy this file to application.properties and fill in your values,
# or set the corresponding environment variables.
# ──────────────────────────────────────────────────────────────

spring.application.name=ecom_backend

server.port=${PORT:${SERVER_PORT:8181}}

# ── PostgreSQL (default) ──────────────────────────────────────
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/ecom_backend}
spring.datasource.username=${DB_USERNAME:postgres}
spring.datasource.password=${DB_PASSWORD:your_password_here}
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

# ── MySQL (uncomment these and comment out the PostgreSQL lines above) ──
# spring.datasource.url=${DB_URL:jdbc:mysql://localhost:3306/ecom_backend}
# spring.datasource.username=${DB_USERNAME:root}
# spring.datasource.password=${DB_PASSWORD:your_password_here}
# spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect

spring.jpa.hibernate.ddl-auto=${JPA_DDL_AUTO:update}

# ── JWT ───────────────────────────────────────────────────────
com.group.project.jwt.secret=${JWT_SECRET:your_jwt_secret_here}
com.group.project.jwt.expires-in=${JWT_EXPIRES_IN:900}

# ── Cookie ────────────────────────────────────────────────────
com.group.project.cookie.name=${COOKIE_NAME:authToken}
com.group.project.cookie.expires-in=${COOKIE_EXPIRES_IN:900}
com.group.project.cookie.secure=${COOKIE_SECURE:<'false' in local. 'true' in prod>}

# ── Frontend ──────────────────────────────────────────────────
com.group.project.frontend.url=${FRONTEND_URL:http://localhost:5173}

# ── Google OAuth2 ─────────────────────────────────────────────
spring.security.oauth2.client.registration.google.client-id=${GOOGLE_CLIENT_ID:your_google_client_id}
spring.security.oauth2.client.registration.google.client-secret=${GOOGLE_CLIENT_SECRET:your_google_client_secret}

# ── Redis ─────────────────────────────────────────────────────
spring.data.redis.host=< host like upstash or something >
spring.data.redis.port=< port. 6379 is like the default for redis >
spring.data.redis.password=< passwrod >
spring.data.redis.ssl.enabled=true
