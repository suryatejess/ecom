# ──────────────────────────────────────────────────────────────
# E-Commerce Platform — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_NAME=ecom_backend
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# For Neon (cloud deployment), use the connection string from your dashboard:
# DB_URL=jdbc:postgresql://ep-xxxx.us-east-2.aws.neon.tech/ecom_backend?sslmode=require

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=900

# ── Cookie ────────────────────────────────────────────────────
COOKIE_NAME=authToken
COOKIE_EXPIRES_IN=900

# ── Google OAuth2 (optional) ─────────────────────────────────
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Ports (local Docker only) ────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8181
DB_PORT=5432

# ── URLs ──────────────────────────────────────────────────────
# The URL the browser uses to reach the backend API
VITE_API_BASE_URL=http://localhost:8181
# The URL the backend uses for CORS and OAuth2 redirects
FRONTEND_URL=http://localhost:3000
